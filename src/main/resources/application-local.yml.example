# 이 파일을 복사해서 application-local.yml 로 만들고, 본인 로컬 DB 정보를 채우세요.
#   cp application-local.yml.example application-local.yml
# application-local.yml 은 git 에 올라가지 않습니다 (.gitignore 등록됨).
spring:
  datasource:
    url: jdbc:mysql://localhost:3306/synq?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
    username: root
    password: your_password_here
    driver-class-name: com.mysql.cj.jdbc.Driver
